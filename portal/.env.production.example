# Production environment template for AMC Research Portal on EC2
# Copy this file to .env and fill in values — never commit .env to git.
# On EC2, this file is written automatically by the GitHub Actions deploy workflow.

# ── Database ───────────────────────────────────────────────────────────────
# On EC2 the DB lives at portal/prod.db (separate from the seed dev.db in git)
DATABASE_URL=file:./prod.db

# ── Auth (NextAuth v5) ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_32_CHAR_RANDOM_SECRET
NEXTAUTH_SECRET=CHANGE_ME_32_CHAR_RANDOM_SECRET
# Set to your EC2 public IP or domain: http://1.2.3.4 or https://your.domain.com
NEXTAUTH_URL=http://YOUR_EC2_PUBLIC_IP

# ── LLM Provider (pick one) ────────────────────────────────────────────────
ACTIVE_LLM=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Web Search ─────────────────────────────────────────────────────────────
SEARCH_PROVIDER=serper
SEARCH_API_KEY=

# ── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
# 7 AM IST = 01:30 UTC
SCHEDULER_CRON=30 1 * * *

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=production
