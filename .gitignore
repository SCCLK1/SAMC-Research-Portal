# dependencies
/portal/node_modules/
/portal/.pnp
/portal/.pnp.*
/portal/.yarn/*

# next.js
/portal/.next/
/portal/out/

# production
/portal/build/

# database
# dev.db is tracked — it is the seed database uploaded to EC2 on the first deploy.
# prod.db lives only on the server and is never committed.
/portal/prod.db
/portal/prod.db-journal
/portal/dev.db-journal

# environment files
/portal/.env*

# debug and logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# system files
.DS_Store
Thumbs.db
